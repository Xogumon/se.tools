{
  "name": "se-tools",
  "version": "2.0.0",
  "description": "Toolkit moderno para desenvolvedores de widgets StreamElements — tipagem completa, tree-shakeable, zero dependências runtime.",
  "type": "module",
  "main": "dist/se-tools.umd.cjs",
  "module": "dist/se-tools.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/se-tools.js",
      "require": "./dist/se-tools.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xogumon/se.tools.git"
  },
  "keywords": [
    "streamelements",
    "widgets",
    "overlay",
    "twitch",
    "typescript",
    "tools"
  ],
  "author": "Ronis Xogum <ronis@xogum.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xogumon/se.tools/issues"
  },
  "homepage": "https://github.com/xogumon/se.tools#readme",
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "happy-dom": "^17.4.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.5"
  }
}
